<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<VBox prefWidth="400.0" prefHeight="400.0" alignment="CENTER" spacing="10.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="sudoku.GameSetupController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="titleLabel" text="Choose Your Puzzle"/>
    <Button fx:id="easyButton" text="Easy" onAction="#launchGame"/>
    <Button fx:id="mediumButton" text="Medium" onAction="#launchGame"/>
    <Button fx:id="hardButton" text="Hard" onAction="#launchGame"/>
</VBox>
